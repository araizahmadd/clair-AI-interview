# Copy to .env and fill in your values from the ElevenLabs dashboard.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Gemini (`interview_agent` resume + question generation)
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-3.1-pro-preview
# Comma-separated fallback chain for transient 503/high-demand errors.
# GEMINI_FALLBACK_MODELS=gemini-2.5-pro,gemini-2.5-flash

# Tavily (optional `--company`)
# TAVILY_API_KEY=

# LangSmith (LangGraph traces) — https://docs.smith.langchain.com/
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=interview-agent

# Cartesia (`interview_agent/voice/` + `--voice`) — https://play.cartesia.ai/
# CARTESIA_API_KEY=
# CARTESIA_AGENT_ID=
# Optional: short-lived token instead of minting from the API key
# CARTESIA_ACCESS_TOKEN=
# Playback sample rate for agent audio (default 44100). Try 24000 if speech sounds wrong.
# CARTESIA_OUTPUT_SAMPLE_RATE=
# Auto-stop the local websocket session after silence (use --manual-stop to disable).
# CARTESIA_AUTO_STOP_AFTER_SILENCE_SECONDS=45
# CARTESIA_MAX_SESSION_SECONDS=900

# Emotion monitor (`--voice` enables it unless `--no-emotion`)
# EMOTION_CAMERA_INDEX=0
# EMOTION_SHOW_WINDOW=false
# HSEMOTION_MODEL=enet_b0_8_best_afew
